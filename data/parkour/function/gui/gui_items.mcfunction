#settings 
execute if items entity @s container.* *[custom_data~{gui:settingsmenuitem}] run function parkour:gui/settings
execute if items entity @s container.* *[custom_data~{gui:settingsmenuitem}] run clear @s *[custom_data~{gui:settingsmenuitem}]

execute if items entity @s player.cursor *[custom_data~{setting:togglefocus}] run scoreboard players add @s focus 1
execute if items entity @s player.cursor *[custom_data~{setting:togglecheckpoints}] run scoreboard players add @s nocheckpoints 1
execute if items entity @s player.cursor *[custom_data~{setting:toggledeathmsg}] run scoreboard players add @s toggle_death_messages 1
execute if items entity @s player.cursor *[custom_data~{setting:togglefeatureditem}] run scoreboard players add @s toggle_featured_item 1
execute if items entity @s player.cursor *[custom_data~{setting:togglealternatehotbar}] run scoreboard players add @s toggle_alternate_hotbar_design 1

execute if items entity @s player.cursor *[custom_data~{gui:settingsmenuitem}] run function parkour:gui/settings